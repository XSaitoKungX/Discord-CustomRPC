{
  "name": "discord-custom-rpc",
  "version": "1.0.1-beta.1",
  "description": "A fully-featured Discord Custom RPC Manager — open source, free for everyone.",
  "main": "./out/main/index.js",
  "author": {
    "name": "XSaitoKungX",
    "email": "mark@xsaitox.dev",
    "url": "https://xsaitox.dev/en"
  },
  "license": "MIT",
  "homepage": "https://xsaitox.dev/en/discord-customrpc",
  "icon": "assets/icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/XSaitoKungX/Discord-CustomRPC"
  },
  "scripts": {
    "dev": "npx @electron/rebuild -f -w better-sqlite3 --silent && electron-vite dev",
    "build": "electron-vite build",
    "build:full": "npm run db:generate && electron-vite build",
    "preview": "electron-vite preview",
    "build:win": "npm run build:full && electron-builder --win --publish never",
    "build:linux": "npm run build:full && electron-builder --linux deb AppImage --publish never",
    "build:mac": "npm run build:full && electron-builder --mac --publish never",
    "build:all": "npm run build:full && electron-builder --win --linux --mac --publish never",
    "release": "npm run build:all -- --publish always",
    "prepare:native": "electron-rebuild -f -w better-sqlite3",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit",
    "changelog": "git-cliff --config cliff.toml -o CHANGELOG.md",
    "changelog:latest": "git-cliff --config cliff.toml --latest --strip header -o RELEASE_NOTES.md"
  },
  "dependencies": {
    "better-sqlite3": "^12.8.0",
    "date-fns": "^4.1.0",
    "discord-rpc": "^4.0.1",
    "drizzle-orm": "^0.45.2",
    "electron-store": "^11.0.2",
    "electron-updater": "^6.8.3",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@electron-toolkit/preload": "^3.0.2",
    "@electron-toolkit/utils": "^4.0.0",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-toast": "^1.2.15",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tailwindcss/vite": "^4.2.2",
    "@types/better-sqlite3": "^7.6.13",
    "@types/discord-rpc": "^4.0.10",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.58.1",
    "@typescript-eslint/parser": "^8.58.1",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.4.27",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dmg-license": "^1.0.11",
    "drizzle-kit": "^0.31.10",
    "electron": "^41.2.0",
    "electron-builder": "^26.8.1",
    "electron-vite": "^5.0.0",
    "eslint": "^10.2.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "lucide-react": "^1.8.0",
    "postcss": "^8.5.9",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-hot-toast": "^2.6.0",
    "react-router-dom": "^7.14.0",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.2",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "^6.0.2",
    "vite": "^8.0.8",
    "zustand": "^5.0.12"
  }
}
